{
	"name": "sogo-db-monorepo",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"dev": "pnpm -r --parallel dev",
		"test": "pnpm -r test",
		"typecheck": "pnpm -r typecheck",
		"lint": "pnpm -r lint",
		"publish:core": "pnpm --filter sogo-db-core publish --access public",
		"publish:mcp": "pnpm --filter sogo-mcp-server publish --access public",
		"publish:npm": "pnpm publish:core && pnpm publish:mcp",
		"package:ext": "pnpm --filter sogo-lite run package",
		"publish:ext": "pnpm --filter sogo-lite run publish",
		"release": "pnpm -r build && pnpm -r test && pnpm publish:npm && pnpm package:ext"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
	"devDependencies": {
		"@vscode/vsce": "^3.7.1"
	}
}
