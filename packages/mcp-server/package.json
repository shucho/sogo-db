{
	"name": "sogo-mcp-server",
	"version": "0.1.0",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"sogo-mcp-server": "bin/sogo-mcp-server.js"
	},
