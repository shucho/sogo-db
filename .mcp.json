{
	"mcpServers": {
		"github": {
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-github"],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
			}
		},
		"sogo-db": {
			"command": "node",
			"args": ["packages/mcp-server/bin/sogo-mcp-server.js"],
			"env": {
				"SOGO_GLOBAL_PATH": "~/.sogo/globalDatabases",
				"SOGO_WORKSPACE_PATH": "."
			}
		}
	}
}
